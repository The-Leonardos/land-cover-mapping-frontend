generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Barangay {
  id                  Int                   @id @default(autoincrement())
  name                String
  landCoverTimeseries LandCoverTimeseries[]

  @@map("barangays")
}

model LandCoverTimeseries {
  barangayId          Int
  year                Int
  quarter             Int
  water               Float
  trees               Float
  grass               Float
  floodedVegetation   Float
  crops               Float
  shrub               Float
  snow                Float
  built               Float
  bare                Float

  barangay            Barangay              @relation(fields: [barangayId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([barangayId, quarter, year])
  @@map("land_cover_timeseries")
}

model LandCoverImageData {
  id          Int     @id @default(autoincrement())
  year        Int
  imageBinary Bytes
  contentType String

  @@map("land_cover_image_data")
}