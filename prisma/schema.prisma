// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

enum TrainingStatus {
  not_started
  training
  trained
}

enum InferenceStatus {
  not_started
  completed
}

model LandCoverTimeSeries {
  barangay_id     String
  barangay_name   String
  year            Int
  quarter         Int
  bare_ground     Float
  built_up_area   Float
  crops           Float
  grass           Float
  shrub_and_scrub Float
  trees           Float
  water           Float

  @@id([barangay_id, year, quarter])
}

model Years {
  year   Int     @id
}

model Models {
  model_id    String      @id @default(uuid())
  model_name  String

  deepLabPerformance DeepLabPerformance[]
  deepvarPerformance DeepVarPerformance[]
}

model ModelsRun {
  forecast_year      Int                @id
  training_status    TrainingStatus     @default(not_started)
  inference_status   InferenceStatus?

  training_date      DateTime?

  deeplabPerformance DeepLabPerformance?
  deepvarPerformance DeepVarPerformance?
}

model DeepLabPerformance {
  forecast_year   String   @id
  model_id       String

  iou            Float?
  accuracy       Float?
  precision      Float?
  recall         Float?
  f1_score       Float?

  model          Models @relation(fields: [model_id], references: [model_id])
  model_run      ModelsRun @relation(fields: [forecast_year], references: [forecast_year])
}

model DeepVarPerformance {
  forecast_year   String   @id
  model_id       String

  mae            Float?
  rmse           Float?
  r2             Float?
  crps           Float?

  model          Models @relation(fields: [model_id], references: [model_id])
  model_run      ModelsRun @relation(fields: [model_run_id], references: [id])
}